{
  "name": "luca-invernizzi-website",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm wrangler types",
    "build:github": "nuxt build --target static --ssr=false --preset=github_pages",
    "build:cloudflare": "nuxt build --ssr=true --preset=cloudflare_module",
    "dev": "nuxt dev",
    "analyze-bundle": "npx nuxi analyze",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler pages dev",
    "postinstall": "nuxt prepare",
    "deploy:cloudflare": "pnpm run build:cloudflare && npx wrangler --cwd .output/ deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npx nuxi typecheck",
    "upgrade": "npx nuxi@latest upgrade --dedupe && pnpm update --latest && pnpm audit fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/robots": "6.0.8",
    "@nuxtjs/sitemap": "^8.0.13",
    "@pinia/nuxt": "0.11.3",
    "@unhead/schema-org": "^3.1.0",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "nuxt": "^4.4.2",
    "nuxt-link-checker": "^5.0.9",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/uil": "^1.2.3",
    "@nuxt/test-utils": "4.0.3",
    "@nuxt/types": "^2.18.1",
    "@testing-library/vue": "^8.1.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "nitro-cloudflare-dev": "^0.2.2",
    "node-glob": "^1.2.0",
    "pinia": "^3.0.4",
    "playwright-core": "^1.59.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.84.1"
  },
  "packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677"
}
